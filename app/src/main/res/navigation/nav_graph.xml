<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.trana.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_navigation"
            app:destination="@id/navigationFragment" />
        <action
            android:id="@+id/action_home_to_profile"
            app:destination="@id/profileFragment" />
    </fragment>

    <fragment
        android:id="@+id/navigationFragment"
        android:name="com.example.trana.NavigationFragment"
        android:label="Navigate"
        tools:layout="@layout/fragment_navigation">
        <action
            android:id="@+id/action_navigation_to_routeMap"
            app:destination="@id/routeMapFragment" />
    </fragment>

    <fragment
        android:id="@+id/routeMapFragment"
        android:name="com.example.trana.RouteMapFragment"
        android:label="Route Map"
        tools:layout="@layout/fragment_route_map">
        <action
            android:id="@+id/action_routeMap_to_routeSelection"
            app:destination="@id/routeSelectionFragment" />
    </fragment>

    <fragment
        android:id="@+id/routeSelectionFragment"
        android:name="com.example.trana.RouteSelectionFragment"
        android:label="Route Selection"
        tools:layout="@layout/fragment_route_selection" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.trana.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />

</navigation>
